{
  "name": "vdex-trading-bot",
  "version": "1.0.0",
  "description": "Automated leverage trading bot for the vDEX API. TypeScript, Node 18+ native fetch, mean-reversion / trend-following execution engine with a strict risk engine.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "tsx src/bot.ts",
    "dev": "tsx watch src/bot.ts",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node dist/bot.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
