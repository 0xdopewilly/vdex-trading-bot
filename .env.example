# ─────────────────────────────────────────────────────────────────────────────
#  vDEX Trading Bot — environment configuration
#  Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentication (REQUIRED) ───────────────────────────────────────────────
# Your vDEX API key. Sent as the `X-API-Key` header on every request.
VDEX_API_KEY=your_api_key_here

# Base URL for the vDEX gateway. Override only if vDEX changes the host.
VDEX_BASE_URL=https://api.vdex.trade/api-gateway

# ── SAFETY ───────────────────────────────────────────────────────────────────
# When true, the bot does EVERYTHING except actually send orders — it logs the
# exact payload it WOULD have submitted. Keep this true until you trust the run.
DRY_RUN=true

# ── Market selection ─────────────────────────────────────────────────────────
# Tokens used by GET /v1/tokens/price/{baseToken}/{quoteToken}.
BASE_TOKEN=ETH
QUOTE_TOKEN=USD

# Optional explicit base_asset_id for order placement. If left blank, the bot
# resolves it at startup from GET /v2/pairs by matching BASE_TOKEN/QUOTE_TOKEN.
BASE_ASSET_ID=

# ── Strategy ─────────────────────────────────────────────────────────────────
# "mean_reversion" or "trend_following"
STRATEGY=mean_reversion

# How often to poll prices (milliseconds). Spec calls for 15s.
POLL_INTERVAL_MS=15000

# Number of samples in the moving-average window (warm-up before trading).
SMA_WINDOW=20

# mean_reversion: fractional deviation from SMA that triggers entry (0.01 = 1%).
ENTRY_THRESHOLD=0.01

# trend_following: fast/slow SMA lengths for the crossover.
FAST_SMA=5
SLOW_SMA=20

# ── Risk engine ──────────────────────────────────────────────────────────────
# Max fraction of available margin committed to a single trade (0.10 = 10%).
MAX_ALLOCATION_PCT=0.10

# Protective bracket on every order, as fractions of entry price.
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.06

# Leverage settings.
LEVERAGE=2
LEVERAGE_TYPE=isolated

# Hard ceiling on simultaneously open positions the bot will manage.
MAX_OPEN_POSITIONS=1

# Floor on available margin (quote currency). Bot will not open below this.
MIN_BALANCE=10

# ── HTTP client ──────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=15000
MAX_RETRIES=4
RETRY_BASE_DELAY_MS=500

# ── Logging ──────────────────────────────────────────────────────────────────
# "debug" | "info" | "warn" | "error"
LOG_LEVEL=info
